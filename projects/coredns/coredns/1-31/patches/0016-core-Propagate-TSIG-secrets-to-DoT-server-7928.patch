From ade9f3b24b00aabd1147b891a5183acbbe271ac8 Mon Sep 17 00:00:00 2001
From: Yong Tang <yong.tang.github@outlook.com>
Date: Mon, 16 Mar 2026 06:42:38 -0700
Subject: [PATCH 16/22] core: Propagate TSIG secrets to DoT server (#7928)

---
 core/dnsserver/server_tls.go      |  1 +
 core/dnsserver/server_tls_test.go | 56 +++++++++++++++++++++++++++++++
 2 files changed, 57 insertions(+)
 create mode 100644 core/dnsserver/server_tls_test.go

diff --git a/core/dnsserver/server_tls.go b/core/dnsserver/server_tls.go
index 4c6faa14c..084ff663a 100644
--- a/core/dnsserver/server_tls.go
+++ b/core/dnsserver/server_tls.go
@@ -53,6 +53,7 @@ func (s *ServerTLS) Serve(l net.Listener) error {
 	// Only fill out the TCP server for this one.
 	s.server[tcp] = &dns.Server{Listener: l,
 		Net:           "tcp-tls",
+		TsigSecret:    s.tsigSecret,
 		MaxTCPQueries: tlsMaxQueries,
 		ReadTimeout:   s.readTimeout,
 		WriteTimeout:  s.writeTimeout,
diff --git a/core/dnsserver/server_tls_test.go b/core/dnsserver/server_tls_test.go
new file mode 100644
index 000000000..01774b26e
--- /dev/null
+++ b/core/dnsserver/server_tls_test.go
@@ -0,0 +1,56 @@
+package dnsserver
+
+import (
+	"errors"
+	"net"
+	"testing"
+)
+
+type stubListener struct {
+	addr net.Addr
+}
+
+func (l *stubListener) Accept() (net.Conn, error) {
+	return nil, errors.New("test listener closed")
+}
+
+func (l *stubListener) Close() error {
+	return nil
+}
+
+func (l *stubListener) Addr() net.Addr {
+	if l.addr != nil {
+		return l.addr
+	}
+	return &net.TCPAddr{IP: net.ParseIP("127.0.0.1"), Port: 0}
+}
+
+func TestServerTLSSetsTsigSecret(t *testing.T) {
+	server, err := NewServerTLS("tls://127.0.0.1:0", []*Config{testConfig("tls", testPlugin{})})
+	if err != nil {
+		t.Fatalf("NewServerTLS() failed: %v", err)
+	}
+
+	server.tsigSecret = map[string]string{
+		"test.": "abcd",
+	}
+
+	l := &stubListener{}
+
+	err = server.Serve(l)
+	if err == nil {
+		t.Fatal("expected Serve() to return from stub listener")
+	}
+
+	if server.server[tcp] == nil {
+		t.Fatal("expected tcp server to be initialized")
+	}
+
+	if server.server[tcp].TsigSecret == nil {
+		t.Fatal("expected TsigSecret to be propagated")
+	}
+
+	if got := server.server[tcp].TsigSecret["test."]; got != "abcd" {
+		t.Fatalf("expected tsig secret %q, got %q", "abcd", got)
+	}
+}
